# Environment variables (contain personal Outlook URL and browser paths)
.env

# User-calibrated scoring config (may contain company/personal-specific patterns)
scoring.json

# Tenant-specific UI reference (capture sessions may contain personal data)
references/outlook-ui.md

# Browser session profile (contains auth cookies — never commit)
.outlook-web-profile/

# Personal assistant workspace (local-only, not part of the skill package)
assistant/

# Browser capture snapshots (may contain tenant URLs and personal data)
snapshot.txt

# Claude Code local settings (may contain personal API keys / hooks)
.claude/

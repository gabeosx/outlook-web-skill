# Outlook Web Skill — Environment Variables
# Copy this file to .env and fill in your values.
#
# Usage: cp .env.example .env  then edit .env with your settings
#
# ── Required ──────────────────────────────────────────────────────────────────

# Your Outlook web URL. Use the URL you see after logging in to Outlook in a browser.
#   Work / school account:  https://outlook.office.com/mail/0/
#   Personal Microsoft:     https://outlook.live.com/mail/0/
#   Custom domain tenant:   https://mail.yourcompany.com
OUTLOOK_BASE_URL=https://outlook.office.com/mail/0/

# Path to the Chrome (or Chromium) executable.
#   macOS default: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux default: /usr/bin/google-chrome
OUTLOOK_BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Directory where the browser stores session cookies / localStorage.
# Use a dedicated profile so this skill's session does not interfere with your
# regular Chrome profile. The directory will be created on first auth run.
#   macOS example: ~/Library/Application Support/Google/Chrome/OutlookSkill
#   Simple option:  ~/.outlook-skill-profile
OUTLOOK_BROWSER_PROFILE=~/.outlook-skill-profile

# ── Optional / Debug ──────────────────────────────────────────────────────────

# Uncomment to open the browser in headed (visible) mode on first auth run:
# OUTLOOK_HEADED=1

# Uncomment to see verbose agent-browser logs on stderr:
# AGENT_BROWSER_DEBUG=1
